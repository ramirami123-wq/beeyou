{% doc %}
  @prompt
    benefits table us vs others
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-benefits-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-benefits-table__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-benefits-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-benefits-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    width: 40%;
  }

  .ai-benefits-table__header-cell--highlight-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_column_background }};
    color: {{ block.settings.highlight_column_text }};
    position: relative;
  }

  .ai-benefits-table__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-benefits-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_alternate_background }};
  }

  .ai-benefits-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-benefits-table__cell--highlight-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_cell_background }};
    font-weight: 600;
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .ai-benefits-table__icon--check-{{ ai_gen_id }} {
    color: {{ block.settings.check_color }};
  }

  .ai-benefits-table__icon--cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-table__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-benefits-table__header-cell-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.header_font_size }}px * 0.85);
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-benefits-table__cell-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.85);
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-benefits-table__badge-{{ ai_gen_id }} {
      font-size: 9px;
      padding: 3px 8px;
    }
  }
{% endstyle %}

<benefits-comparison-{{ ai_gen_id }}
  class="ai-benefits-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-benefits-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-benefits-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-benefits-table__table-{{ ai_gen_id }}">
      <thead class="ai-benefits-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">
            {{ block.settings.feature_column_label }}
          </th>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }} ai-benefits-table__header-cell--highlight-{{ ai_gen_id }}">
            {{ block.settings.us_column_label }}
            {% if block.settings.show_badge %}
              <div class="ai-benefits-table__badge-{{ ai_gen_id }}">
                {{ block.settings.badge_text }}
              </div>
            {% endif %}
          </th>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">
            {{ block.settings.others_column_label }}
          </th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..8) %}
          {% liquid
            assign feature_key = 'feature_' | append: i
            assign us_key = 'us_' | append: i
            assign others_key = 'others_' | append: i

            assign feature = block.settings[feature_key]
            assign us_value = block.settings[us_key]
            assign others_value = block.settings[others_key]
          %}

          {% if feature != blank %}
            <tr class="ai-benefits-table__row-{{ ai_gen_id }}">
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {{ feature }}
              </td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }} ai-benefits-table__cell--highlight-{{ ai_gen_id }}">
                {% if us_value == 'check' %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__icon--check-{{ ai_gen_id }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif us_value == 'cross' %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__icon--cross-{{ ai_gen_id }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ us_value }}
                {% endif %}
              </td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if others_value == 'check' %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__icon--check-{{ ai_gen_id }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif others_value == 'cross' %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__icon--cross-{{ ai_gen_id }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% else %}
                  {{ others_value }}
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</benefits-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('benefits-comparison-{{ ai_gen_id }}', BenefitsComparison{{ ai_gen_id }});
  })();
</script>

