{% doc %}
  @prompt
    benefits table
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-benefits-table__wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__heading-{{ ai_gen_id }} {
    padding: {{ block.settings.heading_padding }}px;
    background-color: {{ block.settings.heading_bg_color }};
    color: {{ block.settings.heading_text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-benefits-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
  }

  .ai-benefits-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.row_border_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    vertical-align: middle;
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    min-width: {{ block.settings.icon_size }}px;
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    fill: {{ block.settings.icon_color }};
  }

  .ai-benefits-table__content-{{ ai_gen_id }} {
    padding-left: {{ block.settings.content_spacing }}px;
  }

  .ai-benefits-table__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 4px 0;
  }

  .ai-benefits-table__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-table__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-benefits-table__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }

    .ai-benefits-table__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-benefits-table__icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      min-width: calc({{ block.settings.icon_size }}px * 0.85);
    }

    .ai-benefits-table__icon-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      height: calc({{ block.settings.icon_size }}px * 0.85);
    }
  }
{% endstyle %}

<benefits-table-{{ ai_gen_id }} class="ai-benefits-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-table__wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-benefits-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <table class="ai-benefits-table__table-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign benefit_enabled_key = 'benefit_' | append: i | append: '_enabled'
          assign benefit_icon_key = 'benefit_' | append: i | append: '_icon'
          assign benefit_title_key = 'benefit_' | append: i | append: '_title'
          assign benefit_description_key = 'benefit_' | append: i | append: '_description'

          assign benefit_enabled = block.settings[benefit_enabled_key]
          assign benefit_icon = block.settings[benefit_icon_key]
          assign benefit_title = block.settings[benefit_title_key]
          assign benefit_description = block.settings[benefit_description_key]
        %}

        {% if benefit_enabled %}
          <tr class="ai-benefits-table__row-{{ ai_gen_id }}">
            <td class="ai-benefits-table__cell-{{ ai_gen_id }} ai-benefits-table__icon-{{ ai_gen_id }}">
              {% case benefit_icon %}
                {% when 'checkmark' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {% when 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                  </svg>
                {% when 'star' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% when 'leaf' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                    <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
                  </svg>
                {% when 'shield' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  </svg>
                {% when 'gift' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 12 20 22 4 22 4 12"></polyline>
                    <rect x="2" y="7" width="20" height="5"></rect>
                    <line x1="12" y1="22" x2="12" y2="7"></line>
                    <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                    <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                  </svg>
                {% when 'truck' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="3" width="15" height="13"></rect>
                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                    <circle cx="5.5" cy="18.5" r="2.5"></circle>
                    <circle cx="18.5" cy="18.5" r="2.5"></circle>
                  </svg>
                {% when 'droplet' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
                  </svg>
              {% endcase %}
            </td>
            <td class="ai-benefits-table__cell-{{ ai_gen_id }} ai-benefits-table__content-{{ ai_gen_id }}">
              {% if benefit_title != blank %}
                <div class="ai-benefits-table__title-{{ ai_gen_id }}">{{ benefit_title }}</div>
              {% endif %}
              {% if benefit_description != blank %}
                <div class="ai-benefits-table__description-{{ ai_gen_id }}">{{ benefit_description }}</div>
              {% endif %}
            </td>
          </tr>
        {% endif %}
      {% endfor %}
    </table>
  </div>
</benefits-table-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('benefits-table-{{ ai_gen_id }}', BenefitsTable{{ ai_gen_id }});
  })();
</script>

